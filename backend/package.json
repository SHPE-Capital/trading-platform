{
  "name": "trading-platform-backend",
  "version": "1.0.0",
  "description": "Event-driven algorithmic trading platform backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:live": "nodemon --exec ts-node src/runtime/live.ts",
    "dev:backtest": "nodemon --exec ts-node src/runtime/backtest.ts",
    "dev:replay": "nodemon --exec ts-node src/runtime/replay.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:live": "node dist/runtime/live.js",
    "start:backtest": "node dist/runtime/backtest.js",
    "start:replay": "node dist/runtime/replay.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "verify:http": "ts-node src/runtime/verify/httpSmoke.ts",
    "verify:backtest": "ts-node src/runtime/verify/backtestVerify.ts"
  },
  "keywords": ["trading", "algorithmic", "hft", "alpaca"],
  "author": "SHPE Capital",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
"@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.24.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
