# ============================================================
# Trading Platform Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ----------------------------------------------------------
# Alpaca API Credentials
# Paper trading uses paper endpoints; live uses live endpoints.
# ----------------------------------------------------------
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# "paper" or "live"
ALPACA_TRADING_MODE=paper

# Paper trading REST endpoint
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Live trading REST endpoint
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# Market data WebSocket endpoint (same for paper and live)
ALPACA_DATA_STREAM_URL=wss://stream.data.alpaca.markets/v2

# Paper trading order stream WebSocket endpoint
ALPACA_PAPER_STREAM_URL=wss://paper-api.alpaca.markets/stream

# Live trading order stream WebSocket endpoint
ALPACA_LIVE_STREAM_URL=wss://api.alpaca.markets/stream

# ----------------------------------------------------------
# Supabase / PostgreSQL
# ----------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Direct Postgres connection string (used for migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ----------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------
PORT=8080
NODE_ENV=development

# CORS origin for the frontend
CORS_ORIGIN=http://localhost:3000

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# ----------------------------------------------------------
# Rolling Window Defaults (milliseconds)
# ----------------------------------------------------------
DEFAULT_ROLLING_WINDOW_MS=60000

# ----------------------------------------------------------
# Risk Defaults
# ----------------------------------------------------------
MAX_POSITION_SIZE_USD=10000
MAX_NOTIONAL_EXPOSURE_USD=50000
ORDER_COOLDOWN_MS=5000

# ----------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------
ENABLE_LIVE_TRADING=false
ENABLE_WEBSOCKET_PUSH=true
