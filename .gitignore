# =============================================================================
# SHPE Capital — Trading Platform — Root .gitignore
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example files committed — they document required vars.

# ── Backend build output ──────────────────────────────────────────────────────
backend/dist/
backend/*.tsbuildinfo

# ── Frontend build output (also covered by frontend/.gitignore) ───────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ── Test / coverage ───────────────────────────────────────────────────────────
coverage/
backend/coverage/
frontend/coverage/
*.lcov

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS / editor artifacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
.vercel
.claude
